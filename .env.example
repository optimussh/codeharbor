PROJECTS_ROOT=./data/projects
TEMPLATES_ROOT=./data/templates
STEERING_ROOT=./data/steering
SPECS_ROOT=./data/specs

# AES key material for credential vault (any long string; hashed to 32 bytes)
CREDENTIALS_MASTER_KEY=dev-only-change-me-32bytes-key!!!!

