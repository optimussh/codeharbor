SESSION_SECRET=change-me-in-local
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_BIN=opencode
OPENCODE_MANAGED=true
OPENCODE_PROVIDER_ID=google
OPENCODE_MODEL_ID=gemini-2.0-flash
