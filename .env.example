RAG_ENABLED=true
RAG_TOP_K=5
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
EMBEDDING_MODEL=text-embedding-004

OPENCHAMBER_ENABLED=true
